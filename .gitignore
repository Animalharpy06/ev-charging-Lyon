# ── Data (never commit raw or processed data) ──────────────────────────────
data/

# ── Outputs (auto-generated at runtime) ────────────────────────────────────
output/

# ── Config (machine-specific paths, never commit) ──────────────────────────
config.yaml

# ── Python cache (auto-generated, useless in git) ──────────────────────────
__pycache__/
*.py[cod]


# ── Virtual environments ────────────────────────────────────────────────────
.venv/